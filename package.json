{
  "name": "hostel-booking-system",
  "version": "1.0.0",
  "private": true,
  "description": "Makerere hostel booking system with a Vite client and Express API",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "npm --prefix server start",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm --prefix client run build",
    "verify:server": "node --check server/server.js",
    "test": "jest --env=node --detectOpenHandles"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mugisharayan/Hostel-Booking-System.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mugisharayan/Hostel-Booking-System/issues"
  },
  "homepage": "https://github.com/mugisharayan/Hostel-Booking-System#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "supertest": "^7.1.4"
  }
}
